# SCsub
import glob

Import("env")
Import("env_modules")


module_env = env_modules.Clone()
module_env.Append(CCFLAGS=['-O2'])

sources = glob.glob("**/*.cpp", recursive=True)
print("c11r sources: ", sources)


if ARGUMENTS.get('c11r', 'static') == 'dynamic':
    # Shared lib compilation
    print("Compiling C11R modules as shared lib")

    module_env.Append(CCFLAGS=['-fPIC'])
    module_env['LIBS'] = []
    shared_lib = module_env.SharedLibrary(target='#bin/c11r', source=sources)
    shared_lib_shim = shared_lib[0].name.rsplit('.', 1)[0]
    env.Append(LIBS=[shared_lib_shim])
    env.Append(LIBPATH=['#bin'])
else:
    # Static compilation
    print("Compiling C11R module as static lib")

    module_env.add_source_files(env.modules_sources, sources)
