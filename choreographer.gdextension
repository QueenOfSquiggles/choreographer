[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.2

[libraries]
linux.debug.x86_64 =     "res://addons/choreographer/target/debug/libchoreographer.so"
linux.release.x86_64 =   "res://addons/choreographer/target/release/libchoreographer.so"
windows.debug.x86_64 =   "res://addons/choreographer/target/debug/choreographer.dll"
windows.release.x86_64 = "res://addons/choreographer/target/release/choreographer.dll"
macos.debug =            "res://addons/choreographer/target/debug/libchoreographer.dylib"
macos.release =          "res://addons/choreographer/target/release/libchoreographer.dylib"
macos.debug.arm64 =      "res://addons/choreographer/target/debug/libchoreographer.dylib"
macos.release.arm64 =    "res://addons/choreographer/target/release/libchoreographer.dylib"
